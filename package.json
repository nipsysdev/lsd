{
  "name": "@nipsys/lsd-monorepo",
  "version": "0.2.5",
  "private": true,
  "description": "Monorepo for the @nipsys/lsd component library and documentation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nipsysdev/lsd.git"
  },
  "author": "Xavier Saliniere <bonjour@xaviers.sh>",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm --filter @nipsys/lsd build",
    "lint": "biome check .",
    "lint:fix": "biome check . --fix",
    "format": "biome format --write .",
    "test": "pnpm --filter @nipsys/lsd test",
    "test:watch": "pnpm --filter @nipsys/lsd test:watch",
    "test:coverage": "pnpm --filter @nipsys/lsd test:coverage",
    "docs:dev": "pnpm --filter @nipsys/lsd-docs dev",
    "docs:build": "pnpm --filter @nipsys/lsd-docs build",
    "docs:preview": "pnpm --filter @nipsys/lsd-docs preview"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "lefthook": "^2.1.0",
    "typescript": "~5.9.3"
  }
}
